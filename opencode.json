{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [],
  "agent": {
    "build": {
      "temperature": 0.2,
      "top_p": 0.8
    }
  },
  "mcp": {
    "serena": {
      "type": "local",
      "command": [
        "uvx",
        "-p",
        "3.13",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context=ide",
        "--project-from-cwd",
        "--open-web-dashboard=False",
      ],
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "enabled": true
    }
  },
  "permission": {
    "edit": "deny",
    "write": "deny",
    "bash": {
      "git commit*": "ask",
      "git push*": "ask",
      "*": "allow"
    }
  },
  "lsp": true
}
