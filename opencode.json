{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [],
  "compaction": {
    "auto": false
  },
  "plugin": ["@tarquinen/opencode-dcp"],
  "command": {
    "dcp": {
      "template": "",
      "description": "DCP panel: context, stats, sweep, manual mode"
    }
  },
  "agent": {
    "plan": {
      "temperature": 0.0,
      "top_p": 0.9
    },
    "build": {
      "temperature": 0.1,
      "top_p": 0.9
    },
    "explore": {
      "temperature": 0.0,
      "top_p": 0.9
    }
  },
  "mcp": {
    "serena": {
      "type": "local",
      "command": [
        "uvx",
        "-p",
        "3.13",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context=ide",
        "--project-from-cwd",
        "--open-web-dashboard=False"
      ],
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "enabled": true
    }
  },
  "permission": {
    "edit": "ask",
    "grep": "deny",
    "bash": {
      "git push": "ask"
    }
  },
  "experimental": {
    "primary_tools": ["compress"]
  },
  "default_agent": "plan",
  "lsp": true
}
